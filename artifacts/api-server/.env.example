# ─── Base de datos ─────────────────────────────────────────────────────────────
# Railway la provee AUTOMÁTICAMENTE al agregar un servicio PostgreSQL.
# No la tenés que configurar manualmente.
DATABASE_URL=postgresql://user:password@host:5432/railway

# ─── MercadoPago ───────────────────────────────────────────────────────────────
# Tu Access Token de PRODUCCIÓN (Panel de MercadoPago → Credenciales)
MP_ACCESS_TOKEN=APP_USR-...

# ─── Panel de administración ───────────────────────────────────────────────────
# La contraseña que usás para entrar a /admin
ADMIN_PASSWORD=tu-contrasena-segura

# ─── URLs de tu sitio ──────────────────────────────────────────────────────────
# FRONTEND_URL → tu URL de Netlify (adonde el cliente vuelve después de pagar)
# API_URL      → tu URL de Railway (adonde MercadoPago envía las notificaciones)
# CORS_ORIGIN  → igual que FRONTEND_URL
#
# Ejemplo:
#   FRONTEND_URL=https://alfis-jeans.netlify.app
#   API_URL=https://alfis-jeans-api.up.railway.app
#   CORS_ORIGIN=https://alfis-jeans.netlify.app
FRONTEND_URL=https://tu-tienda.netlify.app
API_URL=https://tu-api.up.railway.app
CORS_ORIGIN=https://tu-tienda.netlify.app

# ─── Cloudinary (imágenes de productos) ────────────────────────────────────────
# Crear cuenta GRATIS en cloudinary.com → Dashboard → Product Environment Credentials
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
