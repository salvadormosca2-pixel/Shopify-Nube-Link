# Base de datos — Railway la provee automáticamente al agregar PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/railway

# MercadoPago — tu Access Token de producción
MP_ACCESS_TOKEN=APP_USR-...

# Contraseña del panel de administración
ADMIN_PASSWORD=tu-contrasena-segura

# URL del frontend en Netlify (sin barra final)
APP_URL=https://tu-tienda.netlify.app
CORS_ORIGIN=https://tu-tienda.netlify.app

# Cloudinary — para almacenamiento de imágenes de productos
# Crear cuenta gratis en cloudinary.com → Dashboard → Product Environment Credentials
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
